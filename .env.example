POSTGRES_DB=inventory
POSTGRES_USER=postgres
POSTGRES_PASSWORD=changeme

# Full DB URL used by backend
DATABASE_URL=postgresql://postgres:changeme@db:5432/inventory

# Comma-separated list of allowed CORS origins (use * for dev)
ALLOWED_ORIGINS=*

# Frontend: point to the live backend URL when deploying separately
VITE_API_URL=http://localhost:8000
